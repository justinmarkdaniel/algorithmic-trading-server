# Local dev only. In production these come from your secret store
# (AWS SSM Parameter Store, Vault, Doppler, etc.) and are sourced by the
# Docker entrypoint at boot. Never commit a populated .env to git.

# --- Exchange credentials ----------------------------------------------------
# Wire your venue inside `server/exchange/client.py` and source whatever env
# vars that implementation expects. The default is a stub that raises on any
# real call — replace it with a ccxt client (or vendor SDK) before going live.
ACCOUNT1_API_KEY=your_demo_api_key_here
ACCOUNT1_API_SECRET=your_demo_api_secret_here

# --- Engine / venue endpoints ------------------------------------------------
# REST root the live engine fetches klines + flow metrics from. Override per
# venue in `server/engine/live_engine.py`.
EXCHANGE_BASE=https://api.example.com
EXCHANGE_VENUE=exchange

# Default trading symbol (the bot is single-symbol per process).
DEFAULT_SYMBOL=BTC/USDT:USDT
DEFAULT_SYMBOL_NATIVE=BTCUSDT

# --- Server config -----------------------------------------------------------
ALERT_WEBHOOK_URL=
BOT_LOG_DIR=./logs
BOT_CONFIG_PATH=./server/config/production.json

# Comma-separated IPs allowed through the FastAPI middleware. Leave empty
# and set BOT_IP_WHITELIST_DISABLED=1 for local development.
BOT_IP_WHITELIST=127.0.0.1
BOT_IP_WHITELIST_DISABLED=1

# Set to 1 to skip starting the bot tick loop (API-only mode for endpoint dev).
BOT_DISABLE_TICK=0

# Engine warmup — number of historical 5m bars primed at boot. 1500 covers
# ~5 days, enough for most multi-period TA windows.
WARMUP_BARS=1500
